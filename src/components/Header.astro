---
import { SITE, NAV_ITEMS } from '../consts';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="inner">
    <a href="/" class="brand">
      <span class="brand-mark">JX</span>
      <span class="brand-name">{SITE.title}</span>
    </a>
    <nav>
      <ul>
        {NAV_ITEMS.map((item) => {
          const itemPath = item.href.replace(/\/$/, '') || '/';
          const isActive = itemPath === '/'
            ? pathname === '/'
            : pathname === itemPath || pathname.startsWith(itemPath + '/');
          return (
            <li>
              <a href={item.href} class={isActive ? 'active' : ''}>{item.label}</a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: rgba(11, 13, 16, 0.7);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .inner {
    max-width: var(--wide-width);
    margin: 0 auto;
    padding: 0.85rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .brand:hover { color: var(--accent-strong); }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 7px;
    background: linear-gradient(135deg, var(--accent), #4f6fd9);
    color: #0b0d10;
    font-weight: 700;
    font-size: 0.78rem;
    box-shadow: 0 4px 12px rgba(124, 158, 255, 0.25);
  }

  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  nav a {
    display: inline-block;
    padding: 0.4rem 0.7rem;
    color: var(--text-muted);
    border-radius: 6px;
    font-size: 0.92rem;
    transition: background 0.15s ease, color 0.15s ease;
  }

  nav a:hover {
    color: var(--text);
    background: var(--bg-soft);
  }

  nav a.active {
    color: var(--accent-strong);
    background: var(--accent-soft);
  }

  @media (max-width: 540px) {
    .brand-name { display: none; }
    nav a { padding: 0.35rem 0.55rem; font-size: 0.88rem; }
  }
</style>
