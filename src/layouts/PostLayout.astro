---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;
const fmt = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="prose post">
    <header class="post-header">
      <p class="meta faint">
        <time datetime={pubDate.toISOString()}>{fmt.format(pubDate)}</time>
        {updatedDate && (
          <>
            <span aria-hidden="true"> · </span>
            <span>更新于 <time datetime={updatedDate.toISOString()}>{fmt.format(updatedDate)}</time></span>
          </>
        )}
      </p>
      <h1>{title}</h1>
      {description && <p class="lede muted">{description}</p>}
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => (
            <a href={`/tags/${tag}/`} class="tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>
    <div class="post-body">
      <slot />
    </div>
    <footer class="post-footer">
      <a href="/posts/" class="back">← 返回文章列表</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    padding-top: 1rem;
  }
  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .meta {
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }
  .lede {
    margin-top: 0.75rem;
    font-size: 1.05rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }
  .post-body :global(h2) {
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3rem;
  }
  .post-footer {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }
  .back {
    font-size: 0.92rem;
    color: var(--text-muted);
  }
  .back:hover { color: var(--accent-strong); }
</style>
