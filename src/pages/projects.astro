---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';

const projects = [
  {
    name: '个人博客',
    description: '当前你访问的这个站点，基于 Astro 构建，部署在 GitHub Pages。',
    link: 'https://github.com/Xu-Jack11/Xu-Jack11.github.io',
    tags: ['Astro', 'TypeScript', 'GitHub Pages'],
  },
  {
    name: '示例项目占位',
    description: '在这里替换成你正在做的项目。可以删掉一段、复制一段，灵活组合。',
    link: SITE.github,
    tags: ['TODO'],
  },
];
---

<BaseLayout title="项目" description="个人项目与作品">
  <section class="head">
    <h1>项目</h1>
    <p class="muted">
      一些正在做或维护的小东西。更多请见
      <a href={SITE.github} target="_blank" rel="noopener">GitHub</a>。
    </p>
  </section>

  <div class="grid">
    {projects.map((p) => (
      <a class="card" href={p.link} target="_blank" rel="noopener">
        <header>
          <h3>{p.name}</h3>
          <span class="arrow" aria-hidden="true">↗</span>
        </header>
        <p class="muted">{p.description}</p>
        <div class="tags">
          {p.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .head { margin-bottom: 2rem; }
  .head h1 { margin-bottom: 0.25rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .card {
    display: block;
    padding: 1.1rem 1.25rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease, background 0.15s ease;
  }
  .card:hover {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .card header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .card h3 { margin: 0; font-size: 1.1rem; }
  .arrow { color: var(--text-muted); transition: color 0.15s ease; }
  .card:hover .arrow { color: var(--accent-strong); }
  .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.75rem; }
</style>
